PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/apiinsight

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS
CLIENT_ORIGIN=http://localhost:5173

# OpenAI (used for AI test case generation - Milestone 3)
# The server still boots fine without this; only the "generate test cases"
# routes will fail with a clear error until it's set.
OPENAI_API_KEY=gsk_your_key_here
OPENAI_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=https://api.groq.com/openai/v1
